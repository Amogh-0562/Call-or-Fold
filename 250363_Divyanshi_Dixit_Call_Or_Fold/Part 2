"elapsed":5,"user":{"displayName":"Divyanshi Dixit","userId":"11429729603525635412"}}},"execution_count":26,"outputs":[]},{"cell_type":"code","source":["def simulate_penney(seq_a: str, seq_b: str, n_trials: int = 100_000) -> dict:\n","\n","    wins_a = 0\n","    wins_b = 0\n","    total_flips = 0\n","\n","    for _ in range(n_trials):\n","        window = deque(maxlen=3)   # sliding window of last 3 flips\n","        flips = 0\n","        while True:\n","            coin = 'H' if random.random() < 0.5 else 'T'\n","            window.append(coin)\n","            flips += 1\n","            if len(window) == 3:\n","                current = ''.join(window)\n","                if current == seq_a:\n","                    wins_a += 1\n","                    break\n","                if current == seq_b:\n","                    wins_b += 1\n","                    break\n","        total_flips += flips\n","\n","    return {\n","        'seq_a':      seq_a,\n","        'seq_b':      seq_b,\n","        'wins_a':     wins_a,\n","        'wins_b':     wins_b,\n","        'prob_a':     wins_a / n_trials,\n","        'prob_b':     wins_b / n_trials,\n","        'avg_flips':  total_flips / n_trials,\n","        'n_trials':   n_trials,\n","    }\n","\n"],"metadata":{"id":"cmjLsEKZ_8yk","executionInfo":{"status":"ok","timestamp":1780860284884,"user_tz":-330,"elapsed":6,"user":{"displayName":"Divyanshi Dixit","userId":"11429729603525635412"}}},"execution_count":27,"outputs":[]},{"cell_type":"code","source":["\n","print(\"=\" * 60)\n","print(\"PART 1 — HTT vs HTH\")\n","print(\"=\" * 60)\n","\n","N = 100_000\n","r1 = simulate_penney('HTT', 'HTH', N)\n","\n","print(f\"\\n  Trials        : {N:,}\")\n","print(f\"  HTT wins      : {r1['wins_a']:,}  ({r1['prob_a']:.4f})\")\n","print(f\"  HTH wins      : {r1['wins_b']:,}  ({r1['prob_b']:.4f})\")\n","print(f\"  Avg flips/race: {r1['avg_flips']:.2f}\")\n","print(f\"\\n  ➤  Empirical P(HTT wins) ≈ {r1['prob_a']:.4f}  \"\n","      f\"(theoreti