 saved as penneys_game_win_rates.png]\n"]}]},{"cell_type":"code","source":["\n","\n","N_TRIALS = 10_000\n","checkpoints      = list(range(500, N_TRIALS + 1, 500))\n","running_wins     = 0\n","probs_over_time  = []\n","\n","checkpoint_set = set(checkpoints)\n","\n","for i in range(N_TRIALS):\n","\n","    window = deque(maxlen=3)\n","    while True:\n","        coin = 'H' if random.random() < 0.5 else 'T'\n","        window.append(coin)\n","        if len(window) == 3:\n","            current = ''.join(window)\n","            if current == 'HTH':\n","                break\n","            if current == 'THH':\n","                running_wins += 1\n","                break\n","\n","    if (i + 1) in checkpoint_set:\n","        probs_over_time.append(running_wins / (i + 1))\n","\n","fig, ax = plt.subplots(figsize=(10, 4))\n","\n","ax.plot(checkpoints, probs_over_time,\n","        color='#C44E52', linewidth=1.5,\n","        label='Empirical P(THH wins)')\n","\n","ax.axhline(0.75, color='#55A868', linestyle='--', linewidth=1.5,\n","           label='Theoretical 0.75')\n","\n","ax.set_xlabel('Number of trials')\n","ax.set_ylabel('P(THH wins)')\n","ax.set_title('Convergence: THH vs HTH empirical win rate')\n","ax.set_ylim(0.5, 1.0)\n","ax.legend()\n","ax.grid(alpha=0.3)\n","\n","plt.tight_layout()\n","plt.savefig('convergence_THH_vs_HTH.png', dpi=150, bbox_inches='tight')\n","plt.show()\n","print(\"\\n  [Figure saved as convergence_THH_vs_HTH.png]\")\n","print(\"\\n✅  All simulations complete.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":480},"id":"6J-ckm09AX5E","executionInfo":{"status":"ok","timestamp":1780860838223,"user_tz":-330,"elapsed":431,"user":{"displayName":"Divyanshi Dixit","userId":"11429729603525635412"}},"outputId":"d09aa1e0-7cae-456f-d460-c8c9e93926a8"},"execution_count":41,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x400 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","na